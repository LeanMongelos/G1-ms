# Copiar a .env o exportar en el servidor antes de arrancar el backend.
# Perfil prod: SPRING_PROFILES_ACTIVE=prod

SPRING_PROFILES_ACTIVE=prod
SERVER_PORT=8080

DB_URL=jdbc:mysql://localhost:3306/novatech_store?useUnicode=true&characterEncoding=UTF-8&serverTimezone=America/Argentina/Buenos_Aires
DB_USER=novatech_app
DB_PASSWORD=cambiar_en_produccion

# Origen del frontend Angular (sin barra final). Varias URLs separadas por coma.
CORS_ORIGINS=https://tienda.novatech.com.ar

JWT_SECRET=cambiar_por_secreto_largo_aleatorio_minimo_32_chars
JWT_EXPIRATION_MS=86400000
COOKIE_SECURE=true
